{
  "name": "decision-lab-site",
  "private": true,
  "scripts": {
    "dev": "serve .",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,css,js,json,md}\"",
    "check:js": "node --check docs/game.js && node --check app.js && node --check docs/app.js && node --check student-portal.js",
    "cap:prepare": "node scripts/prepare-capacitor-web.mjs",
    "cap:sync": "npm run cap:prepare && cap sync",
    "cap:add:ios": "npm run cap:prepare && cap add ios",
    "cap:add:android": "npm run cap:prepare && cap add android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "prettier": "^3.6.2",
    "serve": "^14.2.5",
    "typescript": "^6.0.2"
  }
}
